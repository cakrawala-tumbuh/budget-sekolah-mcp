# Budget Sekolah MCP — Contoh Konfigurasi
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan server.

# ── Koneksi ke Backend ────────────────────────────────────────────────────────
# Base URL instance budget-backend-ypii yang ingin diakses.
BUDGET_API_BASE_URL=http://api.budget-ypii-2627.local

# Kredensial login ke backend (admin atau user organisasi).
BUDGET_API_USERNAME=admin
BUDGET_API_PASSWORD=changeme

# ── Pengaturan MCP Server ─────────────────────────────────────────────────────
MCP_SERVER_NAME=budget-sekolah-mcp
MCP_LOG_LEVEL=INFO

# ── HTTP Client ───────────────────────────────────────────────────────────────
HTTP_TIMEOUT=30.0

# ── Keamanan (Cloud Deployment) ───────────────────────────────────────────────
# API key untuk mengamankan endpoint HTTP/SSE.
# Jika diisi, setiap request wajib menyertakan salah satu header:
#   X-API-Key: <key>
#   Authorization: Bearer <key>
# Kosongkan (atau hapus baris ini) untuk menonaktifkan autentikasi (lokal/stdio).
# Gunakan string acak yang kuat, minimal 32 karakter, contoh:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=
