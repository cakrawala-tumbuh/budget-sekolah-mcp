# Budget Sekolah MCP — Contoh Konfigurasi
# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan server.

# ── Koneksi ke Backend ────────────────────────────────────────────────────────
# Base URL instance budget-backend-ypii yang ingin diakses.
BUDGET_API_BASE_URL=http://api.budget-ypii-2627.local

# Kredensial login ke backend (admin atau user organisasi).
BUDGET_API_USERNAME=admin
BUDGET_API_PASSWORD=changeme

# ── Pengaturan MCP Server ─────────────────────────────────────────────────────
MCP_SERVER_NAME=budget-sekolah-mcp
MCP_LOG_LEVEL=INFO

# ── HTTP Client ───────────────────────────────────────────────────────────────
HTTP_TIMEOUT=30.0

# ── OAuth via Authentik (untuk Claude.ai / browser-based AI client) ──────────
# URL publik MCP server ini. Wajib diisi jika OAuth Authentik aktif.
MCP_BASE_URL=

# URL dasar Authentik. Contoh: https://auth.cantum-ypii.com
AUTHENTIK_BASE_URL=

# Slug OAuth2/OIDC Provider di Authentik. Contoh: budget-mcp
AUTHENTIK_APP_SLUG=

# Client ID dan Secret dari Authentik OAuth2 Provider.
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Daftar preferred_username Authentik yang diizinkan, dipisah koma.
# Kosongkan untuk mengizinkan semua user yang berhasil login ke Authentik.
# Contoh: andhit-r,user2
AUTHENTIK_ALLOWED_USERNAMES=

# ── API Key (untuk VS Code / tools non-OAuth) ─────────────────────────────────
# API key statis untuk mengamankan endpoint HTTP/SSE.
# Jika diisi, request wajib menyertakan salah satu header:
#   X-API-Key: <key>
#   Authorization: Bearer <key>
# Kosongkan untuk menonaktifkan (lokal/stdio).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=
